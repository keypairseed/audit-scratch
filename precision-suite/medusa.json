{
  "fuzzing": {
    "workers": 4,
    "workerResetLimit": 50,
    "timeout": 21600,
    "testLimit": 0,
    "shrinkLimit": 5000,
    "callSequenceLength": 100,
    "corpusDirectory": "corpus/precision",
    "coverageEnabled": true,
    "targetContracts": ["PrecisionHandler"],
    "targetContractsBalances": [],
    "constructorArgs": {},
    "deployerAddress": "0x30000",
    "senderAddresses": ["0x10000", "0x20000", "0x30000"],
    "blockNumberDelayMax": 60480,
    "blockTimestampDelayMax": 604800,
    "blockGasLimit": 125000000,
    "transactionGasLimit": 12500000,
    "testChainConfig": {
      "codeSizeCheckDisabled": true
    },
    "assertionTesting": {
      "enabled": true,
      "testViewMethods": false,
      "panicCodeConfig": {
        "failOnAssertion": true,
        "failOnArithmeticUnderflow": true,
        "failOnDivideByZero": true
      }
    },
    "propertyTesting": {
      "enabled": true,
      "testPrefixes": ["invariant_", "property_"]
    },
    "optimizationTesting": {
      "enabled": false
    }
  },
  "compilation": {
    "platform": "crytic-compile",
    "platformConfig": {
      "target": ".",
      "compileCommand": "forge build --build-info",
      "targetContracts": [
        "test/invariants/PrecisionStateSpaceInvariant.t.sol"
      ]
    }
  },
  "slither": {
    "useSlither": false
  },
  "logging": {
    "level": "info",
    "logDirectory": "",
    "noColor": false
  }
}
